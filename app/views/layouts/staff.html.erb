<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Massa Mater — Staff</title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "application" %>
  <%= javascript_importmap_tags %>
</head>
<body>
  <nav>
    <%= link_to t("staff.nav.today"),     staff_root_path %>
    <%= link_to t("staff.nav.inventory"), "#" %>
    <%= link_to t("staff.nav.products"),  "#" %>
    <%= link_to t("staff.nav.settings"),  edit_staff_store_hours_path %>

    <span>
      <%= button_to "PT", locale_path(locale: :pt), method: :patch %>
      <%= button_to "EN", locale_path(locale: :en), method: :patch %>
    </span>

    <%= button_to t("auth.sign_out"), logout_path, method: :delete %>
  </nav>

  <main>
    <%= content_tag(:p, flash[:notice], class: "flash-notice") if flash[:notice].present? %>
    <%= content_tag(:p, flash[:alert],  class: "flash-alert")  if flash[:alert].present? %>
    <%= yield %>
  </main>
</body>
</html>
