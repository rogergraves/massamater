<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Massa Mater — Staff</title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "application" %>
  <%= javascript_importmap_tags %>
</head>
<body>
  <nav class="staff-nav">
    <div class="staff-nav-links">
      <%= link_to t("staff.nav.today"),     staff_root_path,              class: "nav-link" %>
      <%= link_to t("staff.nav.inventory"), "#",                          class: "nav-link" %>
      <%= link_to t("staff.nav.products"),  "#",                          class: "nav-link" %>
      <%= link_to t("staff.nav.settings"),  edit_staff_store_hours_path,  class: "nav-link" %>
    </div>
    <div class="staff-nav-right">
      <div class="locale-toggle">
        <%= button_to "PT", locale_path(locale: :pt), method: :patch, class: "locale-btn #{'locale-btn-active' if I18n.locale == :pt}" %>
        <%= button_to "EN", locale_path(locale: :en), method: :patch, class: "locale-btn #{'locale-btn-active' if I18n.locale == :en}" %>
      </div>
      <%= button_to t("auth.sign_out"), logout_path, method: :delete, class: "signout-btn" %>
    </div>
  </nav>

  <main>
    <%= content_tag(:p, flash[:notice], class: "flash-notice") if flash[:notice].present? %>
    <%= content_tag(:p, flash[:alert],  class: "flash-alert")  if flash[:alert].present? %>
    <%= yield %>
  </main>
</body>
</html>
